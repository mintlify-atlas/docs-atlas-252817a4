  "keyFeatures": [
    "Unified API across Slack, Teams, Google Chat, Discord, Telegram, GitHub, and Linear",
    "Event-driven handlers for mentions, messages, reactions, buttons, slash commands, and modals",
    "Thread subscriptions for multi-turn conversations",
    "JSX-based cards and modals that render natively on each platform",
    "AI streaming with native Slack streaming and post+edit fallback",
    "Type-safe TypeScript SDK with full IntelliSense support",
    "Serverless-ready with Redis state adapter and message deduplication",
    "Cross-platform emoji support with type-safe emoji values"
  ],
  "publicApiSurface": [
    "Chat - Main entry point class",
    "createSlackAdapter() - Slack platform adapter",
    "createTeamsAdapter() - Microsoft Teams adapter",
    "createGChatAdapter() - Google Chat adapter",
    "createDiscordAdapter() - Discord adapter",
    "createTelegramAdapter() - Telegram adapter",
    "createGitHubAdapter() - GitHub adapter",
    "createLinearAdapter() - Linear adapter",
    "createRedisState() - Redis state adapter",
    "createIORedisState() - ioredis state adapter",
    "createMemoryState() - In-memory state adapter",
    "Thread - Represents a conversation thread",
    "Channel - Represents a channel/conversation container",
    "Message - Normalized message object",
    "Card, Button, Section, Field - JSX card components",
    "Modal, TextInput, Select - JSX modal components",
    "emoji - Cross-platform emoji utilities",
    "parseMarkdown() - Markdown to AST parser",
    "stringifyMarkdown() - AST to markdown converter"
  ]
}
